# ─────────────────────────────────────────
# YOUR VALUES GO HERE
# This file is gitignored - never commit it
# ─────────────────────────────────────────

aws_region    = "eu-north-1"
key_pair_name = "banking-app"

# YOUR public IP in CIDR format
# Find it by running: curl ifconfig.me
# Then add /32 at the end e.g. 203.0.113.5/32
my_ip_cidr = "YOUR_PUBLIC_IP/32"

# Ubuntu 22.04 LTS AMI for eu-north-1
# Verify at: https://cloud-images.ubuntu.com/locator/ec2/
ubuntu_ami = "ami-07c8c1b18ca66bb07"

# Defaults to on-demand instances so lab nodes can be stopped and started.
use_spot_instances = false
